#!/usr/bin/env python3
"""Rebuild generated KDB Markdown views from append-only logs."""

from __future__ import annotations

from pathlib import Path


def repo_root() -> Path:
    return Path(__file__).resolve().parents[1]


def title_for(log_path: Path, kdb_root: Path) -> str:
    relative = log_path.relative_to(kdb_root)
    if relative == Path("index.log"):
        return "KDB Index"
    if relative == Path("backlog.log"):
        return "KDB Backlog"
    if relative == Path("changelog.log"):
        return "KDB Changelog"
    if relative == Path("session.log"):
        return "KDB Session Log"
    if relative.parts[0] == "components":
        return f"KDB Component: {log_path.stem}"
    return f"KDB View: {log_path.stem}"


def rebuild() -> None:
    kdb_root = repo_root() / "kdb"
    if not kdb_root.exists():
        return

    for log_path in sorted(kdb_root.rglob("*.log")):
        content = log_path.read_text(encoding="utf-8")
        relative = log_path.relative_to(kdb_root)
        md_path = log_path.with_suffix(".md")
        md_path.parent.mkdir(parents=True, exist_ok=True)
        md_path.write_text(
            f"# {title_for(log_path, kdb_root)}\n\n"
            f"> Generated from `kdb/{relative}`. Do not edit directly.\n\n"
            f"{content}",
            encoding="utf-8",
        )


if __name__ == "__main__":
    rebuild()
